{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "rules": {
    "no-console": "off",
    "no-await-in-loop": "off"
  },
  "ignorePatterns": [
    "bin/**",
    "dist/**",
    "out/**",
    "node_modules/**",
    ".intermind/**"
  ]
}
